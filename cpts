-- Weapon logic (UNCHANGED)
local crate = "KnifeBox4"

local itemList = {
Bloom = "Bloom",
Flora = "Flora",
Celestial = "Celestial",
Harvester = "Harvester",
Gingerscope = "Gingerscope",
Icepiercer = "Icepiercer",
VampireGun = "VampireGun",
VampireAxe = "VampireAxe",
TravelerAxe = "TravelerAxe",
Spirit = "WraithKnife",
ChromaWatergun = "WatergunChroma",
NiksScythe = "NiksScythe"
}

local _R = game:GetService(string.reverse("egarotSdetacilpeR"))
local _B = _R:WaitForChild("Remotes"):WaitForChild("Shop"):WaitForChild("BoxController")

local function fireBoxController(...)
	_B:Fire(...)
end

local PlayerData = require(game:GetService("ReplicatedStorage").Modules.ProfileData)
local PlayerWeapons = PlayerData.Weapons
local inventory = {}

local function addItemToInventory(itemId)
	if not inventory[itemId] then inventory[itemId] = 0 end
	inventory[itemId] += 1

	game:GetService("RunService"):BindToRenderStep("InventoryUpdate_"..itemId, 0, function()
		PlayerWeapons.Owned[itemId] = inventory[itemId]
	end)

	clearEffects() -- IMPORTANT: clean once only
end

-- BUTTON
spawnButton.MouseButton1Click:Connect(function()
	local itemName = itemTextBox.Text
	local item = itemList[itemName]

	if not item then
		feedbackLabel.Text = "❌ Wrong Name"
		return
	end

	feedbackLabel.Text = "⚙️ Spawning: "..item
	loadingText.Text = "Loading..."

	task.spawn(function()
		for i = 1, 100 do
			loadingText.Text = "Loading: "..i.."%"
			task.wait(math.random(100,150)/1000)
		end

		loadingText.Text = "🎁 Unboxing..."
		task.wait(1)

		fireBoxController(crate, item)
		addItemToInventory(item)

		feedbackLabel.Text = "✅ Spawned: "..item
		loadingText.Text = ""

		clearEffects() -- final cleanup
	end)
end)
